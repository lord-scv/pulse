# Pulse Configuration
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Default is SQLite. To use PostgreSQL:
# DATABASE_URL=postgres://username:password@localhost:5432/pulse_db
DATABASE_URL=sqlite:///db.sqlite3

# Email Settings (for console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
